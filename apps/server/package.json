{
  "name": "@trade-ai-demo/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:migrate && npm run prisma:generate && tsx watch src/index.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "prisma:migrate": "tsx prisma/applyMigrations.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "openai": "^6.42.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "prisma": "6.16.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
